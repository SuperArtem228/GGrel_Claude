# BondGame environment variables

# Postgres connection (local docker or managed provider)
DATABASE_URL="postgresql://bond:bond@localhost:5432/bondgame?schema=public"

# 32+ random bytes, base64 is fine. Used as session entropy/fallback.
SESSION_SECRET="change-me-to-a-long-random-string"

# Run `npm run vapid` to generate a pair, then paste here.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@bondgame.dev"

# Public subject (exposed to client-side push subscription)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Node env
NODE_ENV="development"
